{
  "name": "wordcamp-schedule-viewer",
  "version": "0.1.0",
  "private": true,
  "description": "Browse upcoming and past WordCamps, live from the WordCamp Central WP REST API.",
  "license": "MIT",
  "author": "Farshid Pourlatifi",
  "repository": {
    "type": "git",
    "url": "https://github.com/farshidpourlatifi/wordcamp-schedule-viewer.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mutation": "stryker run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^2.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "autoprefixer": "^10.5.4",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.19",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
